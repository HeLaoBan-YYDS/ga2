## 验证方法

```bash
# 验证没有旧主题引用
rg -n "VV Ultimatum" ./src/app/ ./src/components/ ./src/locales/

# 验证新主题名称
grep "Grow a Garden 2" ./src/app/[locale]/layout.tsx

# 对比"需求文档链接集合"与"页面实际链接集合"
REQ_LINKS=$(mktemp)
CODE_LINKS=$(mktemp)
rg -No "https?://[^\"' )]+" ./doc/00基础信息.md | sort -u > "$REQ_LINKS"
rg -No "https?://[^\"' )]+" ./src/app/[locale]/page.tsx ./src/locales/en.json 2>/dev/null | sort -u > "$CODE_LINKS"
echo "[仅代码中存在的链接]"; comm -23 "$CODE_LINKS" "$REQ_LINKS"
echo "[仅需求中存在的链接]"; comm -13 "$CODE_LINKS" "$REQ_LINKS"

# 验证 Organization JSON-LD 必填字段（在 layout.tsx 中）
rg -n "\"@type\"\s*:\s*\"Organization\"|\"logo\"\s*:|\"image\"\s*:" ./src/app/[locale]/layout.tsx

# 验证首页输出 og:image / twitter:image / summary_large_image（在 layout.tsx 中）
rg -n "openGraph|twitter|images|summary_large_image" ./src/app/[locale]/layout.tsx
```